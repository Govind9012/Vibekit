{
  "name": "@govindchaudhary/vibekit",
  "version": "0.1.4",
  "description": "Make vibe coding accurate: 3 persistent markdown files (AGENTS.md, CHANGELOG.md, DECISIONS.md) that give any AI coding assistant lean, verifiable context — a lightweight alternative to heavyweight Spec-Driven Development.",
  "keywords": [
    "vibe-coding",
    "ai-coding",
    "agents-md",
    "developer-tools",
    "context",
    "copilot",
    "claude",
    "cursor",
    "windsurf",
    "spec-driven-development"
  ],
  "license": "MIT",
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "vibekit": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "templates",
    "packs",
    "principles-catalog.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
